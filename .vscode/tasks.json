{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "tsgo watch",
      "type": "shell",
      "command": "npm run tsc -- --watch --preserveWatchOutput",
      "problemMatcher": "$tsc-watch",
      "isBackground": true,
      "group": "build"
    },
    {
      "label": "oxlint: run",
      "type": "shell",
      "command": "npm run lint -- -f stylish",
      "problemMatcher": ["$eslint-stylish"],
      "group": "build"
    },
    {
      "label": "generate icons and images",
      "type": "shell",
      "options": {
        "cwd": "${workspaceFolder}/packages/crosswing"
      },
      "command": "npm run gen",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
